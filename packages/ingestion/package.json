{
  "name": "@imaia/ingestion",
  "version": "0.0.0",
  "private": true,
  "description": "Corpus ingestion: legally-clean, LaTeX-aware chunking + embeddings into pgvector (prompt 06).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run",
    "ingest": "tsx src/cli.ts"
  },
  "dependencies": {
    "@imaia/contracts": "workspace:*",
    "@imaia/db": "workspace:*",
    "@prisma/client": "^6.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
