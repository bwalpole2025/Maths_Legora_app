// IMAIA grounded tutor — data layer (prompt 01).
// Provenance / Citation shapes are frozen in context/INTERFACES.md and mirrored
// here; provenance is mandatory per context/CORPUS_POLICY.md.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// Mirror of the frozen union types in INTERFACES.md, enforced at the DB level.
enum SourceType {
  spec
  dfe_content_store
  own_question_bank
  own_authored
}

enum Ownership {
  owned
  licensed
  public
}

model Question {
  id             String   @id @default(cuid())
  stem           String // problem text (LaTeX)
  answer         String? // canonical answer (LaTeX), optional
  curriculumTags String[]

  // Provenance (INTERFACES.md) — additive; licence/ownership are NOT NULL.
  sourceType SourceType
  sourceId   String
  licence    String
  ownership  Ownership

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CorpusChunk {
  id             String                       @id @default(cuid())
  text           String
  curriculumTags String[]
  // Prisma has no first-class vector type; the column migrates and is written
  // via $queryRaw/$executeRaw during ingestion/retrieval (prompts 06/07).
  // Nullable so a chunk can be inserted then have its embedding backfilled.
  embedding      Unsupported("vector(1536)")?

  // Citation (INTERFACES.md)
  citationLabel String // Citation.label
  sourceRef     String // Citation.sourceRef — machine id into the corpus

  // Provenance (INTERFACES.md) — licence/ownership NOT NULL
  sourceType SourceType
  sourceId   String
  licence    String
  ownership  Ownership

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([curriculumTags], type: Gin)
}
