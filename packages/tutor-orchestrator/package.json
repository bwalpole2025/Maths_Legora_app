{
  "name": "@imaia/tutor-orchestrator",
  "version": "0.0.0",
  "private": true,
  "description": "Tutor orchestrator (claim-type routing + gating). Fastify service stub for prompt 00.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "tsc -b && tsc -p tsconfig.test.json --noEmit && vitest run"
  },
  "dependencies": {
    "@imaia/compliance": "workspace:*",
    "@imaia/contracts": "workspace:*",
    "fastify": "^5.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
