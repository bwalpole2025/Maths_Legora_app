{
  "name": "imaia-grounded-tutor",
  "version": "0.0.0",
  "private": true,
  "description": "IMAIA Grounded Tutor — pnpm-workspace monorepo (scaffold, prompt 00)",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b && pnpm --filter @imaia/web build",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:orchestrator": "pnpm --filter @imaia/tutor-orchestrator dev",
    "dev:retrieval": "pnpm --filter @imaia/retrieval dev",
    "dev:web": "pnpm --filter @imaia/web dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
